{# Huawei VRP Interface Template #}
{# Usage: Include in playbooks or use with template module #}
!
interface {{ interface_name }}
 description {{ interface_description | default('Configured by Ansible') }}
 {% if mtu is defined and mtu != 1500 %}
 mtu {{ mtu }}
 {% endif %}
 {% if ip_address is defined and subnet_mask is defined %}
 ip address {{ ip_address }} {{ subnet_mask }}
 {% elif ip_address is defined %}
 ip address {{ ip_address }} 255.255.255.0
 {% endif %}
 {% if interface_enabled | default(true) %}
 undo shutdown
 {% else %}
 shutdown
 {% endif %}
 {% if vrf is defined %}
 ip vrf forwarding {{ vrf }}
 {% endif %}
 {% if bandwidth is defined %}
 bandwidth {{ bandwidth }}
 {% endif %}
 {% if load_interval is defined %}
 load-interval {{ load_interval }}
 {% endif %}
!
{# Additional Huawei VRP interface options #}
{% if switchport_mode is defined %}
 {% if switchport_mode == 'trunk' %}
  port link-type trunk
   {% if allowed_vlans is defined %}
   port trunk allow-pass vlan {{ allowed_vlans }}
   {% endif %}
 {% elif switchport_mode == 'access' %}
  port link-type access
   port default vlan {{ access_vlan | default(1) }}
 {% endif %}
{% endif %}

{% if qos_enabled | default(false) %}
 qos lr {{ qos_cir | default(1000000) }} outbound
 qos lr {{ qos_cir | default(1000000) }} inbound
{% endif %}

{% if loopback is defined and loopback %}
 undo shutdown
 {% endif %}

{% if vlan_batch is defined %}
 vlan batch {{ vlan_batch }}
{% endif %}

{% if ip_helper_addresses is defined %}
 {% for helper in ip_helper_addresses %}
 dhcp relay information option
 dhcp relay server ip {{ helper }}
 {% endfor %}
{% endif %}

{% if stp_enabled | default(true) %}
 stp enable
 {% if stp_mode is defined %}
 stp mode {{ stp_mode }}
 {% endif %}
{% endif %}